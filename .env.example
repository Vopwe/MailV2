# GraphenMail V2 — environment configuration
# Copy to /etc/graphenmail/env on production (chmod 0600) and load via systemd EnvironmentFile.
# For local dev: `cp .env.example .env` and `export $(cat .env | xargs)` before running.

# ─── Flask runtime ──────────────────────────────────────────────────────
FLASK_DEBUG=0
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Stable Flask session secret. Rotate to invalidate all sessions.
# If unset, one is auto-generated to .flask_secret_key on first boot.
FLASK_SECRET_KEY=

# ─── Database ───────────────────────────────────────────────────────────
# Absolute path to SQLite DB. Default: <repo>/emails.db
EMAIL_DB_PATH=/var/lib/graphenmail/emails.db

# ─── Crawler ────────────────────────────────────────────────────────────
# Set to "false" only on networks that MITM outbound TLS via an internal CA.
CRAWL_TLS_VERIFY=true

# ─── Secrets (override settings.json) ───────────────────────────────────
# OpenRouter API key — if set here, the Settings UI value is ignored.
GM_OPENROUTER_API_KEY=

# Pre-hashed admin password (werkzeug format). If set here, Settings UI is read-only.
# Generate with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-pass'))"
GM_APP_PASSWORD_HASH=

# ─── License ────────────────────────────────────────────────────────────
# Path to license.key file (ed25519-signed). Default: /etc/graphenmail/license.key
LICENSE_PATH=/etc/graphenmail/license.key
