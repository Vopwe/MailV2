[Unit]
Description=GraphenMail Email Extractor
After=network.target

[Service]
Type=simple
User=graphenmail
Group=graphenmail
WorkingDirectory=/opt/graphenmail
EnvironmentFile=-/etc/graphenmail/env
ExecStart=/opt/graphenmail/venv/bin/gunicorn --bind 127.0.0.1:5000 --workers 2 --threads 4 --timeout 120 "web:create_app()"
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Environment
Environment=PYTHONUNBUFFERED=1

# Hardening
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
ReadWritePaths=/var/lib/graphenmail /etc/graphenmail /opt/graphenmail

[Install]
WantedBy=multi-user.target
